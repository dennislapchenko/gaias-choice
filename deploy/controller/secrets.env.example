# doco-cd controller secrets — TEMPLATE (keys only, no values).
#
# The REAL file lives ONLY on the VM at /opt/doco-cd/secrets.env (chmod 600,
# git-ignored, never committed). Copy this to secrets.env there and fill it in.
# The doco-cd daemon loads it (env_file) and PASS_ENV=true forwards these into
# the app stack's compose interpolation (deploy/app/compose.yaml). Non-secrets
# (API_DOMAIN / CORS_ORIGINS / BE_TAG) live in .doco-cd.yml, not here.
#
# Mirror of the repo-root .env minus those three non-secrets, plus the
# controller-only APPRISE_NOTIFY_URLS.

# --- infra ---
SERVER_IP=                  # VM public IP (kept out of the public repo)

# --- app: live-edit seam + runtime ---
GITHUB_TOKEN=               # fine-grained PAT, Contents RW on this repo
GIN_MODE=                   # release | debug
DEBUG=                      # backend debug gate (separate from the FE one)

# --- app: bootstrap admin (first boot only) ---
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=   # must be >= 8 chars or the api crash-loops at boot

# --- app: transactional email (magic-link sign-in) ---
POSTMARK_TOKEN=
POSTMARK_STREAM=            # e.g. choice-email
MAIL_FROM=                  # e.g. login@gardenofatlantis.com
PUBLIC_SITE_URL=            # used to build magic-link URLs

# --- app: Telegram sign-in bot ---
TELEGRAM_BOT_TOKEN=         # BotFather token; also feeds APPRISE_NOTIFY_URLS

# --- app: LLM enrich/translate ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=            # optional override

# --- controller: deploy notifications (Apprise → Telegram) ---
# NORMAL PATH: don't hand-write this file — run `task doco:secrets`, which
# generates it from the repo-root .env and DERIVES APPRISE_NOTIFY_URLS from
# TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID (a notify-only knob in .env). This
# template + the explicit line below are the fallback for the from-scratch
# bootstrap path (bootstrap-vm.sh), when there's no laptop .env to push from.
# Always an EXPLICIT chat/channel id — never the chat-id-less form (that
# auto-broadcasts to everyone who DM'd the login bot).
APPRISE_NOTIFY_URLS=        # tgram://<TELEGRAM_BOT_TOKEN>/<chat_id>/
